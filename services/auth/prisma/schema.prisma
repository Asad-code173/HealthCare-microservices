
generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
  
  
}

model User {
  id           String   @id @default(cuid())
  username     String
  email        String   @unique
  password     String
  refreshToken String?
  role         Role     @default(PATIENT)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Role {
  ADMIN
  PATIENT
}



