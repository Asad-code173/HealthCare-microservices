generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

model Appointment {
  id                 String            @id @default(cuid())

  patientName        String
  doctorName         String

  schedule           DateTime
  reason             String

  status             AppointmentStatus @default(PENDING)
  cancellationReason String?

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([schedule])
  @@index([status])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}